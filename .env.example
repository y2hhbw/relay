# =========================
# Relay .env example
# =========================

# ---------------------------------
# Core
# ---------------------------------
# Default in code: sqlite+pysqlite:///./relay.db
RELAY_DATABASE_URL=sqlite+pysqlite:///./relay.db

# ---------------------------------
# Search provider
# ---------------------------------
# mock | duckduckgo
RELAY_SEARCH_PROVIDER_MODE=mock
# Default in code: 5.0
RELAY_SEARCH_PROVIDER_TIMEOUT_SECONDS=5.0

# ---------------------------------
# Chain listener (required for listener process)
# ---------------------------------
# REQUIRED for `python -m app.listener_main`
RELAY_CHAIN_LISTENER_RPC_URL=
# REQUIRED for `python -m app.listener_main`
RELAY_CHAIN_LISTENER_TOKEN_CONTRACT_ADDRESS=

# Default in code: 0
RELAY_CHAIN_LISTENER_START_BLOCK=0
# Default in code: 2
RELAY_CHAIN_LISTENER_CONFIRMATIONS=2
# Default in code: 2.0
RELAY_CHAIN_LISTENER_POLL_INTERVAL_SECONDS=2.0
# Default in code: .relay-listener-state.json
RELAY_CHAIN_LISTENER_STATE_FILE_PATH=.relay-listener-state.json

# Retry / backoff
# Default in code: 1.0
RELAY_CHAIN_LISTENER_RETRY_BACKOFF_SECONDS=1.0
# Default in code: 30.0
RELAY_CHAIN_LISTENER_MAX_RETRY_BACKOFF_SECONDS=30.0

# Alerting
# Default in code: 5
RELAY_CHAIN_LISTENER_ALERT_AFTER_CONSECUTIVE_FAILURES=5
# Default in code: 60.0
RELAY_CHAIN_LISTENER_ALERT_COOLDOWN_SECONDS=60.0
# Optional webhook URL
RELAY_CHAIN_LISTENER_ALERT_WEBHOOK_URL=
